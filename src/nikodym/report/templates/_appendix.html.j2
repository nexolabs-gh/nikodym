{# Anexo: aquí vive el DUMP COMPLETO que antes era el cuerpo del documento. No se pierde nada —
   payloads, tablas crudas y hashes siguen íntegros—; deja de ser lo primero que lee un humano. #}
<section id="{{ section.html_id }}" data-section-id="{{ section.id }}" data-kind="appendix" data-level="{{ section.level }}" class="report-section appendix {% if section.level == 1 %}chapter{% else %}subsection{% endif %}">
  {% if section.level == 1 %}
  <h2>{% if section.number %}<span class="section-number">Anexo {{ section.number }} —</span>{% endif %}{{ section.title }}</h2>
  {% else %}
  <h3 class="subsection-title">{% if section.number %}<span class="section-number">{{ section.number }}</span>{% endif %}{{ section.title }}</h3>
  <p class="source">Artefacto de origen: <code>{{ section.source }}</code></p>
  {% endif %}

  {% for paragraph in section.body %}
  <p>{{ paragraph }}</p>
  {% endfor %}

  {% if section.payload_items %}
  <h4>Parámetros y payload</h4>
  <dl>
    {% for item in section.payload_items %}
    <dt>{{ item.key }}</dt><dd>{% if item.multiline %}<pre>{{ item.value }}</pre>{% else %}{{ item.value }}{% endif %}</dd>
    {% endfor %}
  </dl>
  {% endif %}

  {% if section.metric_items %}
  <h4>Métricas estructuradas</h4>
  <dl>
    {% for item in section.metric_items %}
    <dt>{{ item.key }}</dt><dd>{% if item.multiline %}<pre>{{ item.value }}</pre>{% else %}{{ item.value }}{% endif %}</dd>
    {% endfor %}
  </dl>
  {% endif %}

  {% include "_tables.html.j2" %}

  {% if section.data_exports %}
  {% include "_data_exports.html.j2" %}
  {% endif %}

  {% for figure in section.figures %}
  <figure class="chart-slot" id="{{ figure.html_id }}" data-figure="{{ figure.key }}">
    <figcaption>{{ figure.key }}</figcaption>
  </figure>
  {% endfor %}

  {% if section.narration %}
  {% include "_narration.html.j2" %}
  {% endif %}
</section>
