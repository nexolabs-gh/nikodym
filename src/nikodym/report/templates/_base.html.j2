{# Esqueleto del informe. El CSS se inyecta como |safe (contenido controlado: los selectores `>` y
   las reglas @page romperían el autoescape). Todo lo demás va escapado.
   El tema "nikodym" envuelve el documento en un layout editorial de 3 columnas (sidebar de secciones
   · contenido · índice lateral) que son de PANTALLA: en @media print se ocultan y el documento vuelve
   a una sola columna A4 para el PDF. El tema "plain" mantiene el <main> simple. El bloque `document`
   se define UNA sola vez; el shell (sidebar + rail) se abre/cierra a su alrededor. #}
<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}</title>
  <style>{{ css|safe }}</style>
  {# El encabezado impreso (PDF) repite el título del documento; la hoja base lo trae hardcodeado
     al de scorecard, así que se sobreescribe aquí con el título real de la corrida. #}
  <style>@page { @top-right { content: "{{ document_title }} — CONFIDENCIAL"; } }</style>
</head>
<body>
{% if theme == "nikodym" %}
<div class="doc-shell">
  <aside class="doc-nav">
    <span class="doc-brand">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" aria-hidden="true">
        <g stroke="#2E6FF2" stroke-width="1.8" opacity="0.42">
          <line x1="14" y1="14" x2="50" y2="14"/>
          <line x1="14" y1="14" x2="50" y2="32"/>
          <line x1="14" y1="32" x2="50" y2="14"/>
          <line x1="14" y1="32" x2="50" y2="32"/>
          <line x1="14" y1="32" x2="50" y2="50"/>
          <line x1="14" y1="50" x2="50" y2="32"/>
          <line x1="14" y1="50" x2="50" y2="50"/>
        </g>
        <path d="M14 50 V14 L50 50 V14" fill="none" stroke="#0A2240" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"/>
        <circle cx="14" cy="14" r="4.5" fill="#0A2240"/>
        <circle cx="14" cy="32" r="4.5" fill="#0A2240"/>
        <circle cx="14" cy="50" r="4.5" fill="#0A2240"/>
        <circle cx="50" cy="14" r="4.5" fill="#1859E0"/>
        <circle cx="50" cy="32" r="4.5" fill="#1859E0"/>
        <circle cx="50" cy="50" r="4.5" fill="#1859E0"/>
      </svg>
      <span class="doc-brand-text"><strong>Nikodym</strong><span>Validación de modelos</span></span>
    </span>
    <p class="rail-heading">Contenido</p>
    <nav class="doc-secnav" aria-label="Secciones del informe">
      {% for entry in toc %}
      <a href="{{ entry.href }}" class="lvl-{{ entry.level }}">{{ entry.title }}</a>
      {% endfor %}
    </nav>
  </aside>
{% endif %}
  <main>
{% block document %}{% endblock %}
  </main>
{% if theme == "nikodym" %}
  <aside class="doc-rail">
    <nav class="doc-otp" aria-label="En esta página">
      <p class="rail-heading">En esta página</p>
      {% for entry in toc %}
      {% if entry.level == 1 %}
      <a href="{{ entry.href }}">{{ entry.title }}</a>
      {% endif %}
      {% endfor %}
    </nav>
    <div class="doc-downloads">
      <p class="rail-heading">Entregables</p>
      <div class="dl"><svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 2h6l3 3v9H4z" stroke="currentColor" stroke-width="1.2"/><path d="M9.6 2v3.4H13" stroke="currentColor" stroke-width="1.2"/></svg>HTML<span class="tag">.html</span></div>
      <div class="dl"><svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 2h6l3 3v9H4z" stroke="currentColor" stroke-width="1.2"/><path d="M9.6 2v3.4H13" stroke="currentColor" stroke-width="1.2"/></svg>PDF<span class="tag">.pdf</span></div>
      <div class="dl"><svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 2h6l3 3v9H4z" stroke="currentColor" stroke-width="1.2"/><path d="M9.6 2v3.4H13" stroke="currentColor" stroke-width="1.2"/></svg>Word<span class="tag">.docx</span></div>
      <div class="dl"><svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 2h6l3 3v9H4z" stroke="currentColor" stroke-width="1.2"/><path d="M9.6 2v3.4H13" stroke="currentColor" stroke-width="1.2"/></svg>Fuente editable<span class="tag">.qmd</span></div>
    </div>
  </aside>
</div>
{% endif %}
</body>
</html>
